# Copy this file to ".env" (no extension prefix) and fill in any values you need.
# .env is gitignored — never commit secrets.

# === Ollama (local LLM server) ===
# Default is fine if Ollama runs on this machine
OLLAMA_HOST=http://localhost:11434

# === Optional: override LLM if you swap models later ===
# LLM_MODEL=phi4-mini

# === No API keys needed right now ===
# We dropped Reddit; HN/arXiv/Google News/BMW press all work without auth.
